# Observability stack configuration. Copy to .env and adjust.
#   cp .env.example .env

# --- Grafana admin login -----------------------------------------------------
GF_ADMIN_USER=admin
# CHANGE THIS. It is the Grafana admin password.
GF_ADMIN_PASSWORD=change-me

# --- Networking --------------------------------------------------------------
# The app stack's docker network, joined so Prometheus can scrape app:9091 and
# the postgres exporter can reach the database. Find it with `docker network ls`
# — it is normally <app compose project>_default. If the app stack sets
# COMPOSE_PROJECT_NAME=questboard, this is questboard_default.
APP_NETWORK=questboard_default

# Host interface the Grafana/Prometheus UIs bind to. Keep them on a LAN/VPN
# address in production; 0.0.0.0 exposes them on every host interface.
BIND_ADDR=0.0.0.0

# --- Postgres (must match the app stack's database credentials) --------------
POSTGRES_HOST=postgres
POSTGRES_USER=questboard
POSTGRES_PASSWORD=questboard
POSTGRES_DB=questboard
