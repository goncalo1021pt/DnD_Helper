# Copy to .env and fill in. .env is gitignored.

# --- App ---
APP_ENV=development
APP_ADDR=:8080
# Public URL players reach; used to build OAuth callback URLs.
BASE_URL=http://localhost:8080
# Random secret for signing session cookies. Generate: openssl rand -base64 32
SESSION_KEY=change-me-to-a-long-random-string

# --- Database ---
# When running the Go server on the host against the compose Postgres:
DATABASE_URL=postgres://questboard:questboard@localhost:5432/questboard?sslmode=disable
# Values used by the postgres container (keep in sync with DATABASE_URL):
POSTGRES_USER=questboard
POSTGRES_PASSWORD=questboard
POSTGRES_DB=questboard

# --- OAuth (both optional; enable whichever you configure) ---
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
