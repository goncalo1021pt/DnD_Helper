# Copy to .env and fill in. .env is gitignored.

# --- Environment isolation ---
# Names this stack's containers, network, and DB volume. Use a DISTINCT name per
# environment to run production and a test stack side-by-side on one host:
#   prod:    COMPOSE_PROJECT_NAME=questboard-prod
#   staging: COMPOSE_PROJECT_NAME=questboard-staging
# Separate names => separate pgdata volumes => fully isolated databases.
COMPOSE_PROJECT_NAME=questboard

# --- App ---
APP_ENV=development
APP_ADDR=:8080
# Public URL players reach; used to build OAuth callback URLs.
BASE_URL=http://localhost:8080
# Random secret for signing session cookies. Generate: openssl rand -base64 32
SESSION_KEY=change-me-to-a-long-random-string

# --- Host ports (only for local/LAN access; the tunnel does NOT use these) ---
# Change these if another app on the host already uses 8080 / 5432.
APP_HOST_PORT=8080
POSTGRES_HOST_PORT=5432

# --- Database ---
# When running the Go server on the host against the compose Postgres:
DATABASE_URL=postgres://questboard:questboard@localhost:5432/questboard?sslmode=disable
# Values used by the postgres container (keep in sync with DATABASE_URL):
POSTGRES_USER=questboard
POSTGRES_PASSWORD=questboard
POSTGRES_DB=questboard

# --- Local accounts (username/email + password) ---
# On by default. Users register with an email, a username, and a password
# (bcrypt-hashed, strength-checked) and sign in with either their username or
# their email. Set to "false" to offer OAuth only.
LOCAL_AUTH_ENABLED=true

# --- Transactional email (Resend) — email verification + password recovery ---
# Get an API key at resend.com and verify your sending domain. If RESEND_API_KEY
# is empty, emails are LOGGED to the server console instead of sent — fine for
# local dev, but set it in production so recovery actually works. MAIL_FROM must
# be an address on your verified domain.
RESEND_API_KEY=
MAIL_FROM=Quest Board <no-reply@fontao.net>

# --- OAuth (both optional; enable whichever you configure) ---
# In production (APP_ENV=production) the dev-login shortcut is disabled. With
# local accounts on you already have a login method; configure a provider here
# to also offer one-tap Discord/Google. Redirect/callback URLs to register:
#   ${BASE_URL}/api/auth/discord/callback
#   ${BASE_URL}/api/auth/google/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Cloudflare Tunnel (production deploy) ---
# Token for a remotely-managed tunnel created in the CF Zero Trust dashboard.
# Route the public hostname to http://app:8080 in the dashboard. See DEPLOY.md.
TUNNEL_TOKEN=

# ============================================================================
# PRODUCTION CHECKLIST (set these in the .env on the server):
#   COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml
#     # pins the prod override into every docker compose command (no LAN
#     # postgres, localhost-only app, nightly backup service)
#   APP_ENV=production
#   BASE_URL=https://<your-domain>          # the tunnel's public hostname
#   SESSION_KEY=<openssl rand -base64 32>
#   POSTGRES_PASSWORD=<a strong password>   # DATABASE_URL is set by compose
#   TUNNEL_TOKEN=<from the dashboard>
#   a login method available: LOCAL_AUTH_ENABLED=true (default) and/or a
#     DISCORD_* / GOOGLE_* pair filled in
# ============================================================================
